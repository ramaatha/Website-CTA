<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      Home - Cipta Teknologi Aplikasi - Diversey, Godrej, Prima | General
      Supplier
    </title>
    <meta
      name="description"
      content="Supplier resmi produk chemical cleaning Diversey, Godrej, dan Prima. Harga terbaik langsung dari distributor. Gratis ongkir DKI Jakarta & Bandung."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      /* ═══════════════════════════════════════
       CSS VARIABLES
       ═══════════════════════════════════════ */
      :root {
        --color-primary: #0b3d6b;
        --color-primary-light: #1565a0;
        --color-primary-50: #e8f1fa;
        --color-accent: #00a86b;
        --color-accent-light: #e6f7f0;
        --color-warning: #d4511e;
        --color-warning-light: #fff3ed;
        --color-bg: #fafbfc;
        --color-surface: #ffffff;
        --color-text: #1a2332;
        --color-text-secondary: #5a6577;
        --color-text-tertiary: #8e99a8;
        --color-border: #e2e6ec;
        --color-border-light: #f0f2f5;
        --font-heading: "Plus Jakarta Sans", sans-serif;
        --font-body: "DM Sans", sans-serif;
        --radius-sm: 6px;
        --radius-md: 10px;
        --radius-lg: 16px;
        --radius-xl: 24px;
        --shadow-sm: 0 1px 3px rgba(11, 61, 107, 0.06);
        --shadow-md: 0 4px 16px rgba(11, 61, 107, 0.08);
        --shadow-lg: 0 8px 32px rgba(11, 61, 107, 0.12);
        --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      }

      /* ═══════════════════════════════════════
       RESET & BASE
       ═══════════════════════════════════════ */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: var(--font-body);
        color: var(--color-text);
        background: var(--color-bg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      a {
        text-decoration: none;
        color: inherit;
      }
      img {
        max-width: 100%;
        display: block;
      }
      ul {
        list-style: none;
      }
      h1,
      h2,
      h3,
      h4,
      h5 {
        font-family: var(--font-heading);
        line-height: 1.2;
      }

      /* ═══════════════════════════════════════
       TOP BAR
       ═══════════════════════════════════════ */
      .topbar {
        background: var(--color-primary);
        color: #fff;
        font-size: 13px;
        padding: 8px 0;
      }
      .topbar .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
      }
      .topbar a {
        color: #fff;
      }
      .topbar-hours {
        opacity: 0.85;
      }
      .topbar-phone {
        font-weight: 600;
        letter-spacing: 0.3px;
      }
      .topbar-phone svg {
        vertical-align: -2px;
        margin-right: 4px;
      }

      /* ═══════════════════════════════════════
       CONTAINER
       ═══════════════════════════════════════ */
      .container {
        width: 100%;
        max-width: 1140px;
        margin: 0 auto;
        padding: 0 20px;
      }

      /* ═══════════════════════════════════════
       NAVBAR
       ═══════════════════════════════════════ */
      .navbar {
        background: var(--color-surface);
        border-bottom: 1px solid var(--color-border);
        position: sticky;
        top: 0;
        z-index: 100;
      }
      .navbar .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 68px;
      }
      .nav-logo {
        font-family: var(--font-heading);
        font-weight: 800;
        font-size: 20px;
        color: var(--color-primary);
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .nav-logo-icon {
        width: 36px;
        height: 36px;
        background: var(--color-primary);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 14px;
        font-weight: 800;
      }
      .nav-logo-img {
        height: 32px;
        width: auto;
        object-fit: contain;
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: 4px;
      }
      .nav-links a {
        padding: 8px 16px;
        border-radius: var(--radius-sm);
        font-size: 14px;
        font-weight: 500;
        color: var(--color-text-secondary);
        transition: var(--transition);
      }
      .nav-links a:hover {
        background: var(--color-primary-50);
        color: var(--color-primary);
      }
      .nav-links a.active {
        color: var(--color-primary);
        font-weight: 600;
      }
      .nav-cta {
        background: var(--color-primary) !important;
        color: #fff !important;
        font-weight: 600 !important;
        padding: 10px 20px !important;
        border-radius: var(--radius-md) !important;
      }
      .nav-cta:hover {
        background: var(--color-primary-light) !important;
      }

      /* Hamburger */
      .nav-hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        cursor: pointer;
        padding: 4px;
      }
      .nav-hamburger span {
        width: 24px;
        height: 2px;
        background: var(--color-text);
        border-radius: 2px;
        transition: var(--transition);
      }

      /* ═══════════════════════════════════════
       HERO SECTION
       ═══════════════════════════════════════ */
      .hero {
        background: linear-gradient(
          135deg,
          var(--color-primary) 0%,
          #0e4d85 100%
        );
        padding: 80px 0 100px;
        position: relative;
        overflow: hidden;
      }
      .hero::before {
        content: "";
        position: absolute;
        top: -50%;
        right: -20%;
        width: 600px;
        height: 600px;
        background: radial-gradient(
          circle,
          rgba(0, 168, 107, 0.15) 0%,
          transparent 70%
        );
        border-radius: 50%;
      }
      .hero::after {
        content: "";
        position: absolute;
        bottom: -30%;
        left: -10%;
        width: 400px;
        height: 400px;
        background: radial-gradient(
          circle,
          rgba(255, 255, 255, 0.05) 0%,
          transparent 70%
        );
        border-radius: 50%;
      }
      .hero .container {
        position: relative;
        z-index: 1;
      }
      .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, 0.12);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.15);
        padding: 6px 14px;
        border-radius: 100px;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.9);
        margin-bottom: 24px;
      }
      .hero-badge-dot {
        width: 7px;
        height: 7px;
        background: var(--color-accent);
        border-radius: 50%;
      }
      .hero h1 {
        font-size: clamp(32px, 5vw, 52px);
        font-weight: 800;
        color: #fff;
        max-width: 680px;
        margin-bottom: 20px;
        letter-spacing: -0.5px;
      }
      .hero h1 span {
        color: var(--color-accent);
      }
      .hero-sub {
        font-size: 17px;
        color: rgba(255, 255, 255, 0.75);
        max-width: 520px;
        margin-bottom: 36px;
        line-height: 1.7;
      }
      .hero-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 14px 28px;
        border-radius: var(--radius-md);
        font-family: var(--font-heading);
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        transition: var(--transition);
      }
      .btn-primary {
        background: var(--color-accent);
        color: #fff;
      }
      .btn-primary:hover {
        background: #009b62;
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(0, 168, 107, 0.3);
      }
      .btn-outline {
        background: transparent;
        color: #fff;
        border: 1.5px solid rgba(255, 255, 255, 0.3);
      }
      .btn-outline:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.5);
      }
      .hero-stats {
        display: flex;
        gap: 48px;
        margin-top: 56px;
        padding-top: 32px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
      }
      .hero-stat-value {
        font-family: var(--font-heading);
        font-size: 28px;
        font-weight: 800;
        color: #fff;
      }
      .hero-stat-label {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.55);
        margin-top: 2px;
      }

      /* ═══════════════════════════════════════
       BRAND CAROUSEL
       ═══════════════════════════════════════ */
      .brands {
        padding: 72px 0;
        background: var(--color-surface);
      }
      .section-label {
        font-family: var(--font-heading);
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--color-accent);
        margin-bottom: 12px;
      }
      .section-title {
        font-size: clamp(24px, 3.5vw, 36px);
        font-weight: 800;
        color: var(--color-text);
        margin-bottom: 12px;
        letter-spacing: -0.3px;
      }
      .section-desc {
        font-size: 16px;
        color: var(--color-text-secondary);
        max-width: 520px;
        margin-bottom: 48px;
      }
      .brand-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }
      .brand-card {
        background: var(--color-surface);
        border: 1.5px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 32px 28px;
        text-align: center;
        transition: var(--transition);
        cursor: pointer;
        position: relative;
        overflow: hidden;
      }
      .brand-card:hover {
        border-color: var(--color-primary);
        box-shadow: var(--shadow-md);
        transform: translateY(-4px);
      }
      .brand-card-logo {
        width: 100%;
        max-width: 250px;
        height: auto;
        min-height: 80px;
        margin: 0 auto 20px;
        background: var(--color-bg);
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 12px;
        font-family: var(--font-heading);
        font-weight: 800;
        font-size: 14px;
        color: var(--color-primary);
      }
      .brand-card-logo img {
        width: 100%;
        height: auto;
        max-height: 120px;
        object-fit: contain;
      }
      .brand-card h3 {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 8px;
      }
      .brand-card p {
        font-size: 14px;
        color: var(--color-text-secondary);
        margin-bottom: 20px;
        line-height: 1.6;
      }
      .brand-card-count {
        font-size: 13px;
        color: var(--color-text-tertiary);
        padding-top: 16px;
        border-top: 1px solid var(--color-border-light);
      }
      .brand-card-count strong {
        color: var(--color-primary);
        font-weight: 600;
      }
      .brand-card-arrow {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 32px;
        height: 32px;
        background: var(--color-primary-50);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transform: translate(-4px, 4px);
        transition: var(--transition);
      }
      .brand-card:hover .brand-card-arrow {
        opacity: 1;
        transform: translate(0, 0);
      }

      /* ═══════════════════════════════════════
       WHY BUY DIRECT — PROMO SECTION
       ═══════════════════════════════════════ */
      .promo {
        padding: 72px 0;
        background: var(--color-bg);
      }
      .promo-box {
        background: linear-gradient(135deg, #fff8f3 0%, #fff3ed 100%);
        border: 1.5px solid #f5d5c0;
        border-radius: var(--radius-xl);
        padding: 48px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        align-items: center;
      }
      .promo-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--color-warning);
        color: #fff;
        padding: 5px 12px;
        border-radius: 100px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 16px;
      }
      .promo h2 {
        font-size: 28px;
        font-weight: 800;
        margin-bottom: 16px;
        color: var(--color-text);
      }
      .promo-text {
        font-size: 15px;
        color: var(--color-text-secondary);
        line-height: 1.7;
        margin-bottom: 24px;
      }
      .promo-savings {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #fff;
        border: 1px solid #f0d5c0;
        padding: 12px 20px;
        border-radius: var(--radius-md);
        font-size: 14px;
      }
      .promo-savings strong {
        color: var(--color-warning);
        font-weight: 700;
      }

      /* E-commerce buttons */
      .ecom-grid {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .ecom-btn {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 16px 20px;
        background: #fff;
        border: 1.5px solid var(--color-border);
        border-radius: var(--radius-md);
        transition: var(--transition);
        cursor: pointer;
      }
      .ecom-btn:hover {
        border-color: var(--color-primary);
        box-shadow: var(--shadow-sm);
      }
      .ecom-btn-icon {
        width: 44px;
        height: 44px;
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 11px;
        font-family: var(--font-heading);
        flex-shrink: 0;
      }
      .ecom-btn-info {
        flex: 1;
      }
      .ecom-btn-name {
        font-weight: 600;
        font-size: 14px;
        margin-bottom: 2px;
      }
      .ecom-btn-note {
        font-size: 12px;
        color: var(--color-text-tertiary);
      }
      .ecom-btn-badge {
        font-size: 11px;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 100px;
        flex-shrink: 0;
      }
      .ecom-wa {
        border-color: #25d366;
        background: #f0fff6;
      }
      .ecom-wa:hover {
        background: #e5ffef;
      }
      .ecom-wa .ecom-btn-icon {
        background: #25d366;
        color: #fff;
      }
      .ecom-wa .ecom-btn-badge {
        background: #e6f7f0;
        color: #0f8a4f;
      }

      .ecom-tokped .ecom-btn-icon {
        background: #00aa5b;
        color: #fff;
      }
      .ecom-shopee .ecom-btn-icon {
        background: #ee4d2d;
        color: #fff;
      }
      .ecom-tiktok .ecom-btn-icon {
        background: #1a1a1a;
        color: #fff;
      }

      /* ═══════════════════════════════════════
       ESTIMASI CTA SECTION
       ═══════════════════════════════════════ */
      .estimasi-cta {
        padding: 80px 0;
        background: var(--color-surface);
      }
      .estimasi-box {
        background: linear-gradient(
          135deg,
          var(--color-primary) 0%,
          #0e4d85 100%
        );
        border-radius: var(--radius-xl);
        padding: 56px 48px;
        text-align: center;
        position: relative;
        overflow: hidden;
      }
      .estimasi-box::before {
        content: "";
        position: absolute;
        top: -50%;
        right: -20%;
        width: 400px;
        height: 400px;
        background: radial-gradient(
          circle,
          rgba(0, 168, 107, 0.2) 0%,
          transparent 70%
        );
        border-radius: 50%;
      }
      .estimasi-box > * {
        position: relative;
        z-index: 1;
      }
      .estimasi-box h2 {
        font-size: clamp(24px, 3vw, 32px);
        font-weight: 800;
        color: #fff;
        margin-bottom: 12px;
      }
      .estimasi-box p {
        font-size: 16px;
        color: rgba(255, 255, 255, 0.7);
        max-width: 480px;
        margin: 0 auto 32px;
      }
      .estimasi-features {
        display: flex;
        justify-content: center;
        gap: 32px;
        margin-bottom: 36px;
        flex-wrap: wrap;
      }
      .estimasi-feature {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        color: rgba(255, 255, 255, 0.85);
      }
      .estimasi-feature-icon {
        width: 24px;
        height: 24px;
        background: rgba(255, 255, 255, 0.12);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* ═══════════════════════════════════════
       FOOTER
       ═══════════════════════════════════════ */
      .footer {
        background: var(--color-text);
        color: rgba(255, 255, 255, 0.7);
        padding: 56px 0 32px;
      }
      .footer-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 40px;
        margin-bottom: 40px;
      }
      .footer-brand {
        font-family: var(--font-heading);
        font-weight: 800;
        font-size: 18px;
        color: #fff;
        margin-bottom: 12px;
      }
      .footer-desc {
        font-size: 14px;
        line-height: 1.7;
        margin-bottom: 20px;
      }
      .footer h4 {
        font-family: var(--font-heading);
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #fff;
        margin-bottom: 16px;
      }
      .footer ul li {
        margin-bottom: 10px;
      }
      .footer ul li a {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.6);
        transition: var(--transition);
      }
      .footer ul li a:hover {
        color: #fff;
      }
      .footer-bottom {
        padding-top: 24px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.4);
        flex-wrap: wrap;
        gap: 12px;
      }

      /* ═══════════════════════════════════════
       WHATSAPP FLOATING BUTTON
       ═══════════════════════════════════════ */
      .wa-float {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 999;
        width: 56px;
        height: 56px;
        background: #25d366;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 16px rgba(37, 211, 102, 0.4);
        transition: var(--transition);
        cursor: pointer;
      }
      .wa-float:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 24px rgba(37, 211, 102, 0.5);
      }
      .wa-float svg {
        width: 28px;
        height: 28px;
        fill: #fff;
      }

      /* ═══════════════════════════════════════
       RESPONSIVE
       ═══════════════════════════════════════ */
      @media (max-width: 900px) {
        .brand-grid {
          grid-template-columns: 1fr;
          max-width: 400px;
        }
        .promo-box {
          grid-template-columns: 1fr;
        }
        .footer-grid {
          grid-template-columns: 1fr 1fr;
        }
        .hero-stats {
          gap: 24px;
          flex-wrap: wrap;
        }
      }
      @media (max-width: 768px) {
        .nav-links {
          display: none;
        }
        .nav-hamburger {
          display: flex;
        }
        .nav-links.active {
          display: flex;
          flex-direction: column;
          position: absolute;
          top: 68px;
          left: 0;
          right: 0;
          background: var(--color-surface);
          border-bottom: 1px solid var(--color-border);
          padding: 16px 20px;
          box-shadow: var(--shadow-md);
        }
        .hero {
          padding: 48px 0 64px;
        }
        .hero h1 {
          font-size: 28px;
        }
        .hero-stats {
          gap: 20px;
        }
        .hero-stat-value {
          font-size: 22px;
        }
        .estimasi-box {
          padding: 36px 24px;
        }
        .promo-box {
          padding: 28px 20px;
        }
        .footer-grid {
          grid-template-columns: 1fr;
          gap: 28px;
        }
      }

      /* ═══════════════════════════════════════
       ANIMATIONS
       ═══════════════════════════════════════ */
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .fade-up {
        opacity: 0;
        animation: fadeUp 0.6s ease forwards;
      }
      .fade-up:nth-child(2) {
        animation-delay: 0.1s;
      }
      .fade-up:nth-child(3) {
        animation-delay: 0.2s;
      }

      /* ═══════ FLOATING ESTIMASI CLICKBAIT ═══════ */
      .float-estimasi {
        position: fixed;
        bottom: 24px;
        left: 24px;
        z-index: 998;
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 12px 20px;
        background: var(--color-accent);
        color: #fff;
        border-radius: 100px;
        font-family: var(--font-heading);
        font-size: 13px;
        font-weight: 700;
        box-shadow: 0 4px 20px rgba(0, 168, 107, 0.35);
        transition: var(--transition);
        animation: floatPulse 2.5s ease-in-out infinite;
      }
      .float-estimasi:hover {
        background: var(--color-primary);
        box-shadow: 0 6px 24px rgba(11, 61, 107, 0.35);
        transform: scale(1.05);
        animation: none;
      }
      .float-estimasi-text {
        white-space: nowrap;
      }
      .float-estimasi-icon {
        display: flex;
        animation: bounceArrow 1.5s ease-in-out infinite;
      }
      @keyframes floatPulse {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-4px);
        }
      }
      @keyframes bounceArrow {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(3px);
        }
      }
      @media (max-width: 480px) {
        .float-estimasi {
          left: 16px;
          bottom: 16px;
          font-size: 12px;
          padding: 10px 16px;
        }
      }
    </style>
  </head>
